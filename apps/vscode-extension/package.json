{
  "name": "aiekp",
  "displayName": "AIEKP Reasoning Assistant",
  "description": "Integrates AIEKP Reasoning Engine into VSCode",
  "version": "1.0.0",
  "publisher": "anhtunguyen05",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiekp.startChat",
        "title": "AIEKP: Open Chat",
        "category": "AIEKP"
      },
      {
        "command": "aiekp.askAboutSelection",
        "title": "AIEKP: Ask About Selection/Active File",
        "category": "AIEKP"
      }
    ],
    "configuration": {
      "title": "AIEKP",
      "properties": {
        "aiekp.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "URL of the AIEKP backend API."
        },
        "aiekp.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for AIEKP backend authentication."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  }
}
