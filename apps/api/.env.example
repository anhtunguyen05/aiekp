# -----------------------------------------------------------------------------
# CLOUD DATABASES (Managed by you - e.g. Supabase, Neon, Upstash)
# -----------------------------------------------------------------------------

# PostgreSQL (Cloud)
# Example: postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgres://your_user:your_password@your_cloud_host:5432/your_database?sslmode=require"

# Redis (Cloud)
# Example: rediss://default:[PASSWORD]@[HOST]:[PORT]
REDIS_URL="rediss://default:your_password@your_cloud_host:6379"

# -----------------------------------------------------------------------------
# LOCAL DATABASES (Managed via Docker Compose in /infrastructure)
# -----------------------------------------------------------------------------

# Neo4j (Knowledge Graph)
NEO4J_HOST="localhost"
NEO4J_PORT="7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="aiekp_password"

# Qdrant (Vector DB)
QDRANT_HOST="localhost"
QDRANT_PORT="6333"

# MinIO (Object Storage)
MINIO_HOST="localhost"
MINIO_PORT="9000"
MINIO_ROOT_USER="aiekp_user"
MINIO_ROOT_PASSWORD="aiekp_password"
