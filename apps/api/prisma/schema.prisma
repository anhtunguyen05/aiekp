generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Domain Models will be mapped here in future phases.
// Example placeholder model just to allow generation:
// -----------------------------------------------------------------------------
model KnowledgeNode {
  id        String   @id @default(uuid())
  type      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_nodes")
}
