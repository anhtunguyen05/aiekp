generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Domain Models will be mapped here in future phases.
// Example placeholder model just to allow generation:
// -----------------------------------------------------------------------------
model FileMetadata {
  id              String   @id @default(uuid())
  repo_path       String
  file_path       String
  file_hash       String
  last_scanned_at DateTime @default(now())

  @@unique([repo_path, file_path])
  @@map("file_metadata")
}
